if __name__ == "__main__":
    # 1. Sistemin çalışıp çalışmadığını görmek için örnek bir veri seti oluşturalım
    ornek_veri = pd.DataFrame({
        'kullanici_id': [1, 1, 1, 2, 2, 3, 3, 4],
        'urun_id': ['Telefon', 'Kulaklık', 'Kılıf', 'Telefon', 'Kulaklık', 'Laptop', 'Fare', 'Telefon'],
        'etkilesim_puani': [5, 4, 5, 5, 3, 4, 5, 1] # Puan, tıklama sayısı vs. olabilir
    })

    # 2. Sınıfı çağırıp iskeleti ayağa kaldıralım
    oneri_sistemi = CollaborativeFiltering()

    # 3. Matrisi oluşturalım
    oneri_sistemi.matris_olustur(ornek_veri)

    # 4. Benzerlikleri hesaplayalım
    oneri_sistemi.benzerlik_hesapla()

    # 5. 1 numaralı kullanıcıya en çok benzeyen 2 kişiyi bulalım
    hedef_kullanici = 1
    benzerler = oneri_sistemi.en_benzer_kullanicilari_bul(kullanici_id=hedef_kullanici, getirilecek_kisi_sayisi=2)
    
    print(f"\n{hedef_kullanici} numaralı kullanıcıya en çok benzeyen kullanıcılar ve benzerlik oranları:")
    print(benzerler)
